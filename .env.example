# --- Client (safe to expose; RLS enforces access) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Listing data source: mock | rescuegroups | petfinder (default: rescuegroups)
VITE_DATA_MODE=mock

# OAuth broker: lovable | supabase (default: lovable — current live behaviour).
# "supabase" uses native Supabase Google OAuth and requires the Google provider
# to be configured in the Supabase project.
VITE_OAUTH_PROVIDER=lovable

# Optional Petfinder embed URL for /live-listings
VITE_PETFINDER_WIDGET_URL=

# --- Server-side only (Supabase Edge Function secret; never shipped to client) ---
RESCUEGROUPS_API_KEY=
